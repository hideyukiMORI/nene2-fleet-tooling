{
  "name": "@hideyukimori/nene2-tokens",
  "version": "1.2.0",
  "description": "NeNe Core Token Contract v1 — contract types, CONTRACT_TOKENS, validate:themes CLI, themegen, codemod mapping table v1 + jscodeshift codemod runner, reference theme",
