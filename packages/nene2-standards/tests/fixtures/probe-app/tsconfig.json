{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"], "@tests/*": ["./tests/*"] },
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src", "tests", "jsx-shim.d.ts"]
}
